# ── InvoiceForge Environment Configuration ──────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Flask secret key — change this to a long random string in production
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-before-deploy-use-secrets-token-hex-32

# Environment: "development" enables debug mode + auto-reload
# Use "production" for all deployed instances
FLASK_ENV=production

# Server port (docker-compose and gunicorn both respect this)
PORT=8000

# PDF / invoice limits
MAX_ITEMS=100
MAX_INVOICES=10000

# Optional: override the SQLite database path
# DB_PATH=/data/invoices.db
